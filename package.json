{
  "name": "westpark-self-storage",
  "description": "Westpark Self Storage is a self storage facility in Westpark, Christchurch, New Zealand",
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:next": "npm run dev --workspace=nextjs-app",
    "dev:studio": "npm run dev --workspace=studio",
    "import-sample-data": "cd studio && sanity dataset import sample-data.tar.gz --replace"
  },
  "keywords": [
    "Westpark Self Storage",
    "Self Storage",
    "Storage",
    "Storage Facility",
    "Storage Unit",
    "Storage Space",
    "Storage Solutions",
    "Storage Company",
    "Westpark",
    "Christchurch",
    "New Zealand"
  ],
  "bugs": {
    "url": "https://github.com/sanity-io/sanity-template-nextjs-clean/issues"
  },
  "homepage": "https://www.westparkselfstorage.co.nz",
  "workspaces": [
    "studio",
    "nextjs-app"
  ],
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0"
  }
}
